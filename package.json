    "@mui/icons-material": "latest",
    "@mui/material": "latest",
    "axios": "^1.4.0",
    "framer-motion": "^10.12.22",
    "next": "^13.4.19",
    "react": "latest",
    "react-color": "^2.19.3",
    "react-dom": "latest",
    "react-icons": "^4.10.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "image-size": "^1.0.2",
    "jsonwebtoken": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "mysql": "^2.18.1",
    "node-vibrant": "^3.2.1-alpha.1",
