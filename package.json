{
  "name": "artganizer",
  "version": "5.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"cd backend && nodemon src/index.ts\" \"cd frontend && next dev\"",
    "dev:frontend": "cd frontend && next dev",
    "dev:backend": "cd backend && nodemon src/index.ts",
    "build:frontend": "cd frontend && next build",
    "start": "concurrently \"cd backend && ts-node src/index.ts\" \"cd frontend && next start\"",
    "start:frontend": "cd frontend && next start",
    "start:backend": "cd backend && ts-node src/index.ts"
  },
  "dependencies": {
